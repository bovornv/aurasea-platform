# Dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/
*.lcov

# Production
build/
dist/
*.tsbuildinfo
.next/
out/

# Environment
# (Note: .env files are ignored by *.env pattern in secrets section below)

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
*.code-workspace

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary
tmp/
temp/
.cache/

# Project-specific exclusions
# Crystal Resort real data (data and fixtures only, not code)
**/data/crystal/
**/fixtures/crystal-private/

# Experimental/exploratory code
**/experimental/
**/exploratory/

# Cursor-generated junk
**/.cursor/
**/*cursor-junk*
.turbo/

# API keys and secrets (specific file patterns only)
*.env
*.env.*
.env.local
# Exceptions: allow example/template files to be committed
!.env.example
!.env.sample
*.secret
*.secret.*
*.key.json
*.pem
*.p12
.aider*
