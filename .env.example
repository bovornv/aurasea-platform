# Environment Configuration
NODE_ENV=development

# API Configuration
API_URL=http://localhost:3000
API_KEY=

# Database
DATABASE_URL=

# Authentication
AUTH_SECRET=
AUTH_URL=

# Monitoring
MONITORING_ENABLED=false
MONITORING_API_KEY=

# PostgREST phase-1 cutover (web app): use *_v_next views for selected reads.
# See apps/web/app/lib/supabase/postgrest-phase1-cutover.ts
# NEXT_PUBLIC_POSTGREST_PHASE1_V_NEXT=true
# POSTGREST_PHASE1_V_NEXT=true
#
# Alerts/opportunities track (separate, off by default)
# NEXT_PUBLIC_POSTGREST_ALERTS_V_NEXT=true
# POSTGREST_ALERTS_V_NEXT=true
